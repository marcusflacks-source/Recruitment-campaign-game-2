{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist-lib",
    "declarationDir": "dist-lib"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "dist-lib", "dist-host", "tests", "api", "src/dev"]
}
