{
  "name": "@betterhomes/cast-for-the-catch",
  "version": "1.0.0",
  "private": true,
  "description": "cast for the catch — a fishing mini-game module for the betterhomes recruitment game hub (campaign: trust better. get better.)",
  "type": "module",
  "main": "dist/cast-for-the-catch.js",
  "module": "dist/cast-for-the-catch.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cast-for-the-catch.js"
    },
    "./content/catches.config.json": "./src/content/catches.config.json"
  },
  "files": [
    "dist",
    "src/content/catches.config.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --mode lib",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
