{
  "name": "@betterhomes/cast-for-the-catch",
  "version": "1.0.0",
  "private": true,
  "description": "cast for the catch — a fishing mini-game module for the betterhomes recruitment game hub (campaign: trust better. get better.)",
  "type": "module",
  "main": "dist-lib/cast-for-the-catch.js",
  "module": "dist-lib/cast-for-the-catch.js",
  "types": "dist-lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/cast-for-the-catch.js"
    },
    "./content/catches.config.json": "./src/content/catches.config.json"
  },
  "files": [
    "dist-lib",
    "src/content/catches.config.json"
  ],
  "engines": {
    "node": ">=18.18 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --mode lib && tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "2.1.9"
  }
}
